# ============================================
# DATABASE (Neon Postgres)
# ============================================
DATABASE_URL="postgresql://user:pass@host:port/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:port/db?sslmode=require"

# ============================================
# AUTH (NextAuth)
# ============================================
NEXTAUTH_SECRET="your-32-char-random-string"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-password"
ADMIN_EMAIL="admin@example.com"

# ============================================
# AI (Gemini Manifest Parsing)
# ============================================
GEMINI_API_KEY="your-gemini-api-key"
ADMIN_TIMEZONE="Africa/Lagos"

# ============================================
# GO BACKEND CONNECTION
# ============================================
# Points Next.js Server Actions to the Go REST API.
# Local: http://localhost:5000
# Production: https://your-go-backend.onrender.com (or AWS IP)
BACKEND_URL="http://localhost:5000"

# ============================================
# PUBLIC BRANDING
# ============================================
NEXT_PUBLIC_CONTACT_EMAIL="support@webtracker.com"
NEXT_PUBLIC_CONTACT_PHONE="+1 (555) 123-4567"
NEXT_PUBLIC_CONTACT_HQ="Global Logistics Center"
NEXT_PUBLIC_COMPANY_NAME="Airwaybill"
NEXT_PUBLIC_COMPANY_PREFIX="AWB"

# ============================================
# MONITORING (Sentry)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG="airwaybill"
SENTRY_PROJECT="javascript-nextjs"
# SENTRY_AUTH_TOKEN=

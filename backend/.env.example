# ============================================
# APP CONFIG (Supabase Database)
# ============================================
DATABASE_URL="postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require"
DIRECT_URL="postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require"

# ============================================
# SERVER CONFIG
# ============================================
API_PORT=8080
VPS_IP="127.0.0.1"
TRACKING_BASE_URL="http://localhost:3000"

# ============================================
# PAYMENTS (Paystack)
# ============================================
PAYSTACK_SECRET_KEY="sk_test_..."

# ============================================
# AI / GEMINI (Manifest Parsing)
# ============================================
GEMINI_API_KEY="AIzaSy..."

# ============================================
# SYSTEM EMAILS (Brevo)
# ============================================
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@example.com"
SMTP_PASSWORD="your-smtp-password"
NOTIFY_EMAIL="admin@yourcompany.com"

# ============================================
# GLOBAL SETTINGS
# ============================================
WHATSAPP_ALLOW_PRIVATE_CHAT=false
ADMIN_TIMEZONE="Africa/Lagos"
USE_OPTIMIZED_RECEIPT=true
# ============================================
# APP CONFIG (Supabase Database)
# ============================================
# HOW TO GET: Go to Supabase Dashboard -> Project Settings -> Database -> Connection String (URI)
DATABASE_URL="postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require"
DIRECT_URL="postgresql://[user]:[password]@[host]:[port]/[db]?sslmode=require"

# ============================================
# SERVER CONFIG
# ============================================
API_PORT=8080
VPS_IP="127.0.0.1"
FRONTEND_URL="http://localhost:3000"
SUPERADMIN_COMPANY_ID=""
HEALTHCHECK_URL=""
LOG_PATH=""
LOG_LEVEL="info"
WORKER_POOL_SIZE=5
BUFFER_SIZE=100

# ============================================
# PAYMENTS (Paystack)
# ============================================
# HOW TO GET: Go to Paystack Dashboard -> Settings -> API Keys & Webhooks -> Secret Key
PAYSTACK_SECRET_KEY="sk_test_..."

# ============================================
# AI / GEMINI (Manifest Parsing)
# ============================================
# HOW TO GET: Google AI Studio -> Get API Key
GEMINI_API_KEY="AIzaSy..."

# ============================================
# SYSTEM EMAILS (Brevo)
# ============================================
# HOW TO GET: Brevo Dashboard -> SMTP & API -> SMTP
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@example.com"
SMTP_PASSWORD="your-smtp-password"
NOTIFY_EMAIL="admin@yourcompany.com"

# ============================================
# GLOBAL SETTINGS
# ============================================
WHATSAPP_ALLOW_PRIVATE_CHAT=false
ADMIN_TIMEZONE="Africa/Lagos"
USE_OPTIMIZED_RECEIPT=true
JWT_SECRET="your-jwt-secret-here"
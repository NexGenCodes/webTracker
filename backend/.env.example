# ==============================================================================
# DATABASE CONFIGURATION (PostgreSQL / Neon)
# ==============================================================================
# The primary database connection URL (usually the pooled connection for Neon)
DATABASE_URL="postgresql://user:pass@host:port/db?sslmode=require"

# Direct connection URL (optional, used for migrations or debugging)
DIRECT_URL="postgresql://user:pass@host:port/db?sslmode=require"

# Dedicated database for running automated tests
TEST_DATABASE_URL="postgresql://user:pass@host:port/test_db?sslmode=require"

# ==============================================================================
# APP SERVER CONFIGURATION
# ==============================================================================
# Port for the Fiber REST API server (default: 5000)
API_PORT=5000

# Base URL for the frontend tracking application
TRACKING_BASE_URL="http://localhost:3000"

# Official name of the logistics company
COMPANY_NAME="Airwaybill"

# Timezone used for administrative tasks and logs (e.g., Africa/Lagos)
ADMIN_TIMEZONE="Africa/Lagos"

# ==============================================================================
# WHATSAPP BOT CONFIGURATION
# ==============================================================================
# The phone number to pair with the bot (international format, e.g., +234...)
WHATSAPP_PAIRING_PHONE="+2340000000000"

# Whether to allow the bot to respond in private chats (true/false)
WHATSAPP_ALLOW_PRIVATE_CHAT=false

# Comma-separated list of admin phone numbers (+234...)
WHATSAPP_ADMIN_PHONES="+2340000000000"

# The primary owner's phone number for critical notifications
BOT_OWNER_PHONE="+2340000000000"

# ==============================================================================
# AI & EXTERNAL SERVICES
# ==============================================================================
# Google Gemini API key for manifest parsing and AI features
GEMINI_API_KEY="your-gemini-api-key"

# ==============================================================================
# MONITORING & LOGGING
# ==============================================================================
# URL to ping for healthchecks (e.g., Healthchecks.io)
HEALTHCHECK_URL="https://hc-ping.com/your-uuid"

# Directory where log files will be stored
LOG_PATH="/var/log/bot"

# Log level (debug, info, warn, error, fatal) - default: info
LOG_LEVEL="info"

# ==============================================================================
# NOTIFICATIONS (SMTP / Email)
# ==============================================================================
# SMTP Server hostname
SMTP_HOST="smtp.gmail.com"

# SMTP Server port (usually 465 for SSL or 587 for TLS)
SMTP_PORT=465

# SMTP Account username
SMTP_USERNAME="your-email@gmail.com"

# SMTP Account password (use an App Password for Gmail)
SMTP_PASSWORD="your-app-password"

# Recipient email for system notifications
NOTIFY_EMAIL="your-recipient@gmail.com"